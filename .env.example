# Copy this file to ".env" and fill in your free API keys.
# Everything still runs offline if these are missing (mock fallbacks kick in).

# Free tier: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Free tier: https://console.groq.com/keys
GROQ_API_KEY=

# --- AWS deployment (used by the deploy scripts / Terraform / CI, not the app) ---
# The application itself needs none of these to run locally. They configure the
# AWS App Runner deployment described in docs/DEPLOYMENT.md.
# AWS_REGION=us-east-1
# ECR_REPOSITORY=multi-signal-demand-forecasting
# IMAGE_TAG=latest
# S3 zones are created by Terraform; names are emitted via `terraform output`:
#   CURATED_BUCKET=multi-signal-demand-forecasting-curated-<account-id>
#   ARTIFACTS_BUCKET=multi-signal-demand-forecasting-artifacts-<account-id>
